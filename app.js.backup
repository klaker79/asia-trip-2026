  { id: 'passport_iker', label: '🛂 Pasaporte Iker', critical: true },
  { id: 'passport_anais', label: '🛂 Pasaporte Anais', critical: true },
  { id: 'seguro_medico', label: '🏥 Seguro médico', critical: true },
